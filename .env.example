# ─── HustleScale Environment Configuration ───

# ─── LLM Provider (pick ONE — all have free tiers) ───
# Options: groq (default, FREE), openrouter (FREE models), openai, anthropic
LLM_PROVIDER=groq

# Groq — FREE, no credit card needed
# Sign up: https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_your_free_key_here
# LLM_MODEL=llama-3.3-70b-versatile

# OpenRouter — FREE models available
# Sign up: https://openrouter.ai → API Keys
# OPENROUTER_API_KEY=sk-or-...
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Anthropic Claude — premium, paid (optional)
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-6-20250514
# CLAUDE_THINKING_BUDGET=10000
# CLAUDE_PROMPT_CACHING=true

# ─── LLM Settings ───
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3
LLM_CONTEXT_WINDOW=8192

# ─── Application ───
APP_ENV=development
LOG_LEVEL=info
PORT=8808
AUTH_DB_PATH=data/hustle_scale_auth.db

# ─── Qdrant Vector Store ───
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=hustle_coach_kb
DENSE_MODEL=BAAI/bge-m3
DENSE_DIM=1024
RERANKER_MODEL=mixedbread-ai/mxbai-rerank-base-v2
RERANK_ENABLED=true
GROUNDING_THRESHOLD=0.3
BM25_STATE_PATH=knowledge-base/bm25_state.json

# ─── Redis (cache + rate limiting) ───
REDIS_URL=redis://redis:6379/0
CACHE_BACKEND=redis
CACHE_ENABLED=true
CACHE_THRESHOLD=0.92
CACHE_TTL_SECONDS=3600

# ─── Multilingual ───
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,lg,sw,nyn

# ─── Safety & Guardrails ───
MAX_INPUT_LENGTH=2000
ABSTENTION_THRESHOLD=0.15
ESCALATION_THRESHOLD=0.25

# ─── Security ───
ALLOWED_ORIGINS=http://localhost:3440,http://localhost:8808
# JWT_SECRET is REQUIRED for production — use a strong random string:
#   openssl rand -hex 32
# If not set, a random secret is generated on startup (tokens invalidate on restart)
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=72
REQUEST_TIMEOUT=30

# ─── Rate Limiting ───
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW=60
# Auth-specific limits (per IP, per minute)
# Login: 5 attempts/min, Signup: 3 attempts/min (hardcoded in main.py)

# ─── Privacy (Uganda NDPA compliant) ───
STORE_RAW_PROMPTS=false
CONVERSATION_TTL_DAYS=7

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:8808
NEXT_PUBLIC_APP_NAME=HustleScale
NEXT_PUBLIC_BASE_URL=http://localhost:3440
